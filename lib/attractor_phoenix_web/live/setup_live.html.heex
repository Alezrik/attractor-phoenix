<Layouts.app
  flash={@flash}
  current_scope={assigns[:current_scope]}
  current_path={~p"/setup"}
  page_title={@page_title}
  page_kicker="Provider Control"
  page_subtitle="Credential entry, model discovery, and default-generation policy now share the same product shell as the builder and dashboard."
>
  <:actions>
    <button
      id="shell-refresh-provider-settings"
      type="submit"
      form="setup-form"
      name="setup[action]"
      value="refresh_models"
      class="builder-btn"
    >
      Get Settings
    </button>
  </:actions>
  <:status>
    <Layouts.shell_status_item>
      <span class="shell-status-label">Default Route</span>
      <span class="shell-status-value">
        {if @settings.default_model, do: @settings.default_model, else: "Not selected"}
      </span>
      <span class="shell-status-note">
        {if @settings.default_provider,
          do: String.capitalize(@settings.default_provider),
          else: "Set after discovery"}
      </span>
    </Layouts.shell_status_item>
    <Layouts.shell_status_item>
      <span class="shell-status-label">Provider Coverage</span>
      <span class="shell-status-value">{configured_provider_count(@settings)} / 3</span>
      <span class="shell-status-note">
        {discovered_model_count(@settings)} discovered models in inventory
      </span>
    </Layouts.shell_status_item>
  </:status>
  <section class="space-y-8" id="setup-page">
    <section class="setup-control-grid">
      <article class="setup-control-hero">
        <div>
          <p class="dashboard-card-label">Provider control room</p>
          <h2 class="mt-3 text-2xl font-semibold sm:text-3xl">
            Scan provider health before touching credentials.
          </h2>
          <p class="mt-3 max-w-3xl text-sm leading-7 text-base-content/72">
            The route now prioritizes health, recency, mode, and default-role clarity so operators
            can understand readiness at a glance before working through form density.
          </p>
        </div>

        <div class="setup-summary-grid" id="setup-summary-grid">
          <article class="setup-summary-card">
            <p class="setup-summary-label">Providers configured</p>
            <p class="setup-summary-value">{configured_provider_count(@settings)}</p>
            <p class="setup-summary-note">API-backed or CLI-backed</p>
          </article>
          <article class="setup-summary-card">
            <p class="setup-summary-label">Models discovered</p>
            <p class="setup-summary-value">{discovered_model_count(@settings)}</p>
            <p class="setup-summary-note">Across all provider inventories</p>
          </article>
          <article class="setup-summary-card">
            <p class="setup-summary-label">Default generator</p>
            <p class="setup-summary-value text-lg">
              {if @settings.default_provider,
                do:
                  "#{String.capitalize(@settings.default_provider)} / #{@settings.default_model}",
                else: "Not selected"}
            </p>
            <p class="setup-summary-note">Applied to builder create flows</p>
          </article>
        </div>
      </article>

      <aside class="setup-route-links" id="setup-route-links">
        <p class="dashboard-card-label">Execution routes</p>
        <div class="mt-4 grid gap-2">
          <.link navigate={~p"/builder"} class="library-route-link">Builder authoring</.link>
          <.link navigate={~p"/library"} class="library-route-link">Library launchpads</.link>
          <.link navigate={~p"/benchmark"} class="library-route-link">Benchmark priorities</.link>
        </div>
      </aside>
    </section>

    <.inline_error :if={@error} id="setup-error" title="Setup failed" message={@error} />

    <section class="grid gap-4 xl:grid-cols-[1.15fr_0.85fr]" id="setup-proof-packet">
      <article class="dashboard-panel space-y-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="dashboard-card-label">Shared proof packet</p>
            <h2 class="mt-3 text-xl font-semibold">Provider readiness proof boundary</h2>
            <p class="mt-2 text-sm leading-6 text-base-content/70">
              Current provider readiness is {support_phrase(@proof_packet)}. Proof artifact: {@proof_packet.proof_artifact}. Known limit: {@proof_packet.known_limits}.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class={[
              "rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em]",
              proof_status_tone(@proof_packet.status)
            ]}>
              status {@proof_packet.status}
            </span>
            <span class={[
              "rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em]",
              proof_status_tone(@proof_packet.claim_level)
            ]}>
              claim {@proof_packet.claim_level}
            </span>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <%= for {label, value} <- proof_fields(@proof_packet) do %>
            <div class="rounded-3xl border border-base-300 bg-base-200/35 px-4 py-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-base-content/55">
                {label}
              </p>
              <p class="mt-2 text-sm leading-6 text-base-content/80">{value}</p>
            </div>
          <% end %>
        </div>
      </article>

      <article class="dashboard-panel space-y-4">
        <div>
          <p class="dashboard-card-label">Proof language guide</p>
          <p class="mt-3 text-sm leading-6 text-base-content/72">
            Setup now uses the same proof record fields as benchmark reporting so readiness,
            evidence, and known limits stay in one contract.
          </p>
        </div>

        <div class="space-y-3 text-sm leading-6 text-base-content/75">
          <p>
            <strong>supported by:</strong>
            configured providers, discovered models, and default routing all exist in the saved snapshot.
          </p>
          <p>
            <strong>partially supported by:</strong>
            some readiness evidence exists, but the setup state is incomplete or blocked.
          </p>
          <p>
            <strong>not yet proven:</strong>
            no configured provider or usable inventory is visible yet.
          </p>
          <p>
            <strong>known limit:</strong>
            this route does not prove latency, cost, or quality by itself.
          </p>
        </div>
      </article>
    </section>

    <section class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
      <article class="setup-form-card">
        <div>
          <p class="dashboard-card-label">Credential and fetch controls</p>
          <h2 class="mt-3 text-xl font-semibold">Provider Credentials</h2>
          <p class="mt-2 text-sm leading-6 text-base-content/68">
            Save keys here, then fetch live inventories. Sensitive values stay obscured while the
            health board below carries the scannable state.
          </p>
        </div>

        <.form for={@setup_form} id="setup-form" phx-submit="submit_setup" class="mt-6 space-y-4">
          <.input
            field={@setup_form[:openai]}
            id="setup-openai-key"
            type="password"
            label="OpenAI API Key"
          />
          <div class="setup-openai-mode-panel">
            <.input
              field={@setup_form[:openai_mode]}
              id="setup-openai-mode"
              type="select"
              label="OpenAI Mode"
              options={[{"Direct API", "api"}, {"Codex CLI", "cli"}]}
            />
            <.input
              field={@setup_form[:openai_cli_command]}
              id="setup-openai-cli-command"
              type="text"
              label="Codex Command"
            />
            <p
              class="text-xs leading-5 text-base-content/60 md:col-span-2"
              phx-no-curly-interpolation
            >
              Use CLI mode if you want to generate through the local <code>codex</code>
              tool
              instead of OpenAI API billing. Command templates must include <code>{prompt}</code>.
              The default template is <code>codex exec --full-auto {prompt}</code>. Add
              <code>{model}</code>
              only if you want the selected model passed through to the CLI.
            </p>
          </div>
          <.input
            field={@setup_form[:anthropic]}
            id="setup-anthropic-key"
            type="password"
            label="Anthropic API Key"
          />
          <.input
            field={@setup_form[:gemini]}
            id="setup-gemini-key"
            type="password"
            label="Gemini API Key"
          />

          <div class="flex flex-wrap gap-2">
            <button
              id="save-setup-keys"
              name="setup[action]"
              value="save_keys"
              type="submit"
              class="builder-btn"
            >
              Save Keys
            </button>
            <button
              id="refresh-provider-settings"
              name="setup[action]"
              value="refresh_models"
              type="submit"
              class="ui-button ui-button-primary"
            >
              Get Settings
            </button>
          </div>
        </.form>
      </article>

      <div class="space-y-4">
        <article class="setup-default-card">
          <div>
            <p class="dashboard-card-label">Default role routing</p>
            <h2 class="mt-3 text-xl font-semibold">Default Generation Model</h2>
            <p class="mt-2 text-sm leading-6 text-base-content/68">
              Set the default builder generation route after inventory has been fetched.
            </p>
          </div>

          <.form
            for={@default_form}
            id="default-model-form"
            phx-submit="save_default"
            class="mt-5 space-y-4"
          >
            <.input
              field={@default_form[:selection]}
              id="default-model-selection"
              type="select"
              label="Default provider/model"
              prompt="Choose a discovered model"
              options={
                Enum.map(AttractorPhoenix.LLMSetup.available_models(), fn model ->
                  {"#{String.capitalize(model.provider)} / #{model.id}",
                   "#{model.provider}::#{model.id}"}
                end)
              }
            />

            <button id="save-default-model" type="submit" class="ui-button ui-button-primary">
              Save Default
            </button>
          </.form>
        </article>

        <article class="setup-default-card">
          <p class="dashboard-card-label">What the board is showing</p>
          <div class="mt-4 space-y-3 text-sm leading-6 text-base-content/72">
            <p><strong>Status:</strong> key presence, fetch result, and model readiness.</p>
            <p>
              <strong>Recency:</strong>
              last sync time or whether the provider has never been queried.
            </p>
            <p><strong>Mode:</strong> direct API vs CLI-backed OpenAI execution.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="grid gap-4 lg:grid-cols-3">
      <%= for provider <- ["openai", "anthropic", "gemini"] do %>
        <% entry = @settings.providers[provider] %>
        <article id={"provider-card-#{provider}"} class="setup-provider-card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-base-content/55">
                {provider}
              </p>
              <h3 class="mt-2 text-xl font-semibold">{String.capitalize(provider)}</h3>
              <p class="mt-2 text-sm text-base-content/68">Health, inventory, and route role</p>
            </div>
            <span class={["setup-health-pill", provider_health_tone(entry)]}>
              {provider_health_label(entry)}
            </span>
          </div>

          <div class="setup-provider-meta-grid">
            <div class="setup-provider-meta">
              <span class="setup-provider-meta-label">Credential</span>
              <strong>{provider_key_status(entry)}</strong>
            </div>
            <div class="setup-provider-meta">
              <span class="setup-provider-meta-label">Mode</span>
              <strong>{String.upcase(entry.mode)}</strong>
            </div>
            <div class="setup-provider-meta">
              <span class="setup-provider-meta-label">Last sync</span>
              <strong>{provider_recency(entry)}</strong>
            </div>
            <div class="setup-provider-meta">
              <span class="setup-provider-meta-label">Default role</span>
              <strong>
                {if @settings.default_provider == provider,
                  do: "Current default",
                  else: "Available"}
              </strong>
            </div>
          </div>

          <%= if provider == "openai" and entry.mode == "cli" do %>
            <div class="setup-command-note">
              <p class="setup-provider-meta-label">CLI command</p>
              <p class="mt-2 break-all font-mono text-[11px]">{entry.cli_command}</p>
            </div>
          <% end %>

          <%= if entry.last_error do %>
            <p class="setup-provider-error">{entry.last_error}</p>
          <% end %>

          <div class="mt-5">
            <div class="flex items-center justify-between gap-3">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/55">
                Models
              </p>
              <span class="text-xs text-base-content/55">{length(entry.models)} available</span>
            </div>

            <div id={"provider-models-#{provider}"} class="mt-3 space-y-2">
              <%= if entry.models == [] do %>
                <.empty_state
                  title="No models discovered yet"
                  message="Save a key or switch modes, then fetch the provider inventory."
                  icon="hero-squares-plus"
                />
              <% end %>

              <%= for model <- entry.models do %>
                <div class="setup-model-row">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-mono text-xs">{model.id}</span>
                    <%= if @settings.default_provider == provider and @settings.default_model == model.id do %>
                      <span class="rounded-full bg-amber-500/20 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-amber-700">
                        default
                      </span>
                    <% else %>
                      <span class="text-[10px] font-semibold uppercase tracking-[0.14em] text-base-content/50">
                        standby
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </section>
  </section>
</Layouts.app>
