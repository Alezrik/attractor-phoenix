<Layouts.app flash={@flash} current_scope={assigns[:current_scope]} current_path={~p"/setup"}>
  <section class="space-y-8" id="setup-page">
    <div class="rounded-[1.75rem] border border-base-300/70 bg-[radial-gradient(circle_at_top_left,rgba(14,165,233,0.18),transparent_34%),linear-gradient(135deg,rgba(255,255,255,0.94),rgba(248,250,252,0.92))] p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)] dark:bg-[radial-gradient(circle_at_top_left,rgba(14,165,233,0.14),transparent_30%),linear-gradient(135deg,rgba(15,23,42,0.92),rgba(15,23,42,0.84))]">
      <p class="builder-kicker">Setup</p>
      <div class="space-y-3">
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">LLM Providers and Defaults</h1>
        <p class="max-w-3xl text-sm leading-6 text-base-content/70">
          Configure API keys for OpenAI, Anthropic, and Gemini, fetch the models available to
          your account, and choose one global default provider/model pair for builder generation.
        </p>
      </div>
    </div>

    <%= if @error do %>
      <div
        id="setup-error"
        class="rounded-2xl border border-error/30 bg-error/10 px-4 py-3 text-sm text-error"
      >
        {@error}
      </div>
    <% end %>

    <section class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
      <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold">Provider Credentials</h2>
            <p class="mt-1 text-sm text-base-content/65">
              Save keys here, then use Get Settings to query each provider for models currently
              available to that key.
            </p>
          </div>
        </div>

        <.form for={@setup_form} id="setup-form" phx-submit="submit_setup" class="mt-5 space-y-4">
          <.input
            field={@setup_form[:openai]}
            id="setup-openai-key"
            type="password"
            label="OpenAI API Key"
          />
          <div class="grid gap-4 rounded-2xl border border-base-300/70 bg-base-200/30 p-4 md:grid-cols-[0.5fr_1fr]">
            <.input
              field={@setup_form[:openai_mode]}
              id="setup-openai-mode"
              type="select"
              label="OpenAI Mode"
              options={[{"Direct API", "api"}, {"Codex CLI", "cli"}]}
            />
            <.input
              field={@setup_form[:openai_cli_command]}
              id="setup-openai-cli-command"
              type="text"
              label="Codex Command"
            />
            <p
              class="text-xs leading-5 text-base-content/60 md:col-span-2"
              phx-no-curly-interpolation
            >
              Use CLI mode if you want to generate through the local <code>codex</code>
              tool
              instead of OpenAI API billing. Command templates must include <code>{prompt}</code>.
              The default template is <code>codex exec --full-auto {prompt}</code>.
              Add <code>{model}</code>
              only if you want the selected model passed through to the CLI.
            </p>
          </div>
          <.input
            field={@setup_form[:anthropic]}
            id="setup-anthropic-key"
            type="password"
            label="Anthropic API Key"
          />
          <.input
            field={@setup_form[:gemini]}
            id="setup-gemini-key"
            type="password"
            label="Gemini API Key"
          />

          <div class="flex flex-wrap gap-2">
            <button
              id="save-setup-keys"
              name="setup[action]"
              value="save_keys"
              type="submit"
              class="rounded-lg border border-base-300 bg-base-100 px-4 py-2 text-sm font-semibold transition hover:bg-base-200"
            >
              Save Keys
            </button>
            <button
              id="refresh-provider-settings"
              name="setup[action]"
              value="refresh_models"
              type="submit"
              class="rounded-lg bg-sky-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-400"
            >
              Get Settings
            </button>
          </div>
        </.form>
      </article>

      <article class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm">
        <h2 class="text-lg font-semibold">Default Generation Model</h2>
        <p class="mt-1 text-sm text-base-content/65">
          The Create dialog will use this provider/model by default, but users can still override
          it per generation.
        </p>

        <.form
          for={@default_form}
          id="default-model-form"
          phx-submit="save_default"
          class="mt-5 space-y-4"
        >
          <.input
            field={@default_form[:selection]}
            id="default-model-selection"
            type="select"
            label="Default provider/model"
            prompt="Choose a discovered model"
            options={
              Enum.map(AttractorPhoenix.LLMSetup.available_models(), fn model ->
                {"#{String.capitalize(model.provider)} / #{model.id}",
                 "#{model.provider}::#{model.id}"}
              end)
            }
          />

          <button
            id="save-default-model"
            type="submit"
            class="rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-amber-400"
          >
            Save Default
          </button>
        </.form>
      </article>
    </section>

    <section class="grid gap-4 lg:grid-cols-3">
      <%= for provider <- ["openai", "anthropic", "gemini"] do %>
        <% entry = @settings.providers[provider] %>
        <article
          id={"provider-card-#{provider}"}
          class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm"
        >
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-base-content/55">
                {provider}
              </p>
              <h3 class="mt-2 text-xl font-semibold">{String.capitalize(provider)}</h3>
            </div>
            <span class={[
              "rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em]",
              entry.api_key == "" && "bg-base-200 text-base-content/60",
              entry.api_key != "" && entry.last_error == nil && "bg-success/15 text-success",
              entry.last_error != nil && "bg-error/15 text-error"
            ]}>
              <%= cond do %>
                <% entry.api_key == "" -> %>
                  no key
                <% entry.last_error != nil -> %>
                  error
                <% true -> %>
                  ready
              <% end %>
            </span>
          </div>

          <div class="mt-4 space-y-3 text-sm">
            <p>
              Key: <strong>{if entry.api_key == "", do: "not saved", else: "saved"}</strong>
            </p>
            <p>
              Mode: <strong>{String.upcase(entry.mode)}</strong>
            </p>
            <%= if provider == "openai" and entry.mode == "cli" do %>
              <p>
                Command:
                <strong class="break-all font-mono text-[11px]">{entry.cli_command}</strong>
              </p>
            <% end %>
            <p>
              Last sync: <strong>{entry.last_synced_at || "never"}</strong>
            </p>
            <%= if entry.last_error do %>
              <p class="rounded-xl border border-error/30 bg-error/10 px-3 py-2 text-xs text-error">
                {entry.last_error}
              </p>
            <% end %>
          </div>

          <div class="mt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/55">
              Models
            </p>

            <div id={"provider-models-#{provider}"} class="mt-3 space-y-2">
              <%= if entry.models == [] do %>
                <p class="rounded-xl border border-dashed border-base-300 px-3 py-4 text-sm text-base-content/60">
                  No models discovered yet.
                </p>
              <% end %>

              <%= for model <- entry.models do %>
                <div class="rounded-xl border border-base-300/70 px-3 py-2 text-sm">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-mono text-xs">{model.id}</span>
                    <%= if @settings.default_provider == provider and @settings.default_model == model.id do %>
                      <span class="rounded-full bg-amber-500/20 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-amber-700">
                        default
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </section>
  </section>
</Layouts.app>
