<Layouts.app
  flash={@flash}
  current_scope={assigns[:current_scope]}
  current_path={if @live_action == :create, do: ~p"/create", else: ~p"/builder"}
  page_title={@page_title}
  page_kicker={if @live_action == :create, do: "AI Drafting", else: "Graph Studio"}
  page_subtitle="The shell now carries route identity, actions, and state while the builder stays focused on graph authoring, validation, and execution."
>
  <:actions>
    <button id="open-command-palette" type="button" class="builder-btn">
      Command Palette <span class="builder-shortcut-pill">Ctrl+K</span>
    </button>
    <.link navigate={~p"/create"} id="open-create-dialog" class="builder-btn">
      Create with AI
    </.link>
    <.link navigate={~p"/library"} class="builder-btn">Open Library</.link>
  </:actions>
  <:status>
    <Layouts.shell_status_item>
      <span class="shell-status-label">Workspace</span>
      <span class="shell-status-value">
        {if @live_action == :create, do: "Create dialog open", else: "Canvas editing"}
      </span>
      <span class="shell-status-note">
        DOT and graph JSON stay paired in one authoring surface
      </span>
    </Layouts.shell_status_item>
    <Layouts.shell_status_item>
      <span class="shell-status-label">Library Context</span>
      <span class="shell-status-value">
        {if @loaded_library_entry, do: @loaded_library_entry.name, else: "Scratch graph"}
      </span>
      <span class="shell-status-note">
        {if @loaded_library_entry,
          do: @loaded_library_entry.id,
          else: "Nothing loaded from saved presets"}
      </span>
    </Layouts.shell_status_item>
  </:status>
  <%= if @live_action == :create do %>
    <dialog
      id="create-dialog"
      open
      class="fixed inset-0 z-50 grid h-screen w-screen place-items-center bg-transparent p-0 backdrop:bg-black/55"
    >
      <div class="w-[min(96vw,48rem)] rounded-[1.75rem] border border-base-300 bg-base-100 p-6 shadow-[0_32px_100px_rgba(15,23,42,0.28)]">
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-2">
            <p class="builder-kicker">Create</p>
            <h2 class="text-2xl font-bold tracking-tight">Describe the workflow in English</h2>
            <p class="max-w-2xl text-sm leading-6 text-base-content/70">
              The app will generate a DOT pipeline, validate it against the local AttractorEx
              runtime, and load it into the builder for review.
            </p>
          </div>
          <.link navigate={~p"/builder"} id="close-create-dialog" class="builder-btn">
            Close
          </.link>
        </div>

        <%= if @create_error do %>
          <div
            id="create-dialog-error"
            class="mt-4 rounded-2xl border border-error/30 bg-error/10 px-4 py-3 text-sm text-error"
          >
            {@create_error}
          </div>
        <% end %>

        <.form
          for={@create_form}
          id="create-pipeline-form"
          phx-hook="CreateProgressTimer"
          phx-change="change_create"
          phx-submit="generate_dot"
          class="mt-5 space-y-4 phx-submit-loading:pointer-events-none"
        >
          <.input
            field={@create_form[:prompt]}
            id="create-prompt"
            type="textarea"
            label="What should this pipeline do?"
            rows="8"
            placeholder="Example: Review a pull request, ask a human for approval if tests fail, then publish a release summary."
          />

          <div class="grid gap-4 md:grid-cols-2">
            <.input
              field={@create_form[:provider]}
              id="create-provider"
              type="select"
              label="Provider"
              prompt="Choose a provider"
              options={@create_provider_options}
            />

            <.input
              field={@create_form[:model]}
              id="create-model"
              type="select"
              label="Model"
              prompt="Choose a model"
              options={@create_model_options}
            />
          </div>

          <p class="text-xs leading-5 text-base-content/60">
            Add or refresh provider models in <.link
              navigate={~p"/setup"}
              class="font-semibold text-sky-600 hover:text-sky-500"
            >
              Setup
            </.link>.
          </p>

          <div
            id="create-progress-panel"
            class="create-progress hidden rounded-[1.25rem] border border-amber-300/45 bg-amber-50/80 p-4 text-slate-900 phx-submit-loading:block"
          >
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-700/75">
                  Generation
                </p>
                <p class="mt-1 text-sm font-semibold" data-create-status>Ready</p>
              </div>
              <div class="rounded-full border border-slate-900/10 bg-white/70 px-3 py-1 text-xs font-semibold">
                <span data-create-elapsed>0s</span>
              </div>
            </div>

            <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-900/8">
              <div class="create-progress-bar h-full rounded-full"></div>
            </div>

            <p class="mt-3 text-xs leading-5 text-slate-700/75">
              You will either return to Builder with the generated DOT loaded, or stay here with a validation error.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <button
              id="generate-create-dot"
              type="submit"
              phx-disable-with="Generating DOT..."
              class="rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-amber-400 disabled:cursor-wait disabled:opacity-75"
            >
              Generate DOT
            </button>
            <.link
              navigate={~p"/builder"}
              class="builder-btn phx-submit-loading:pointer-events-none phx-submit-loading:opacity-50"
            >
              Cancel
            </.link>
          </div>
        </.form>
      </div>
    </dialog>
  <% end %>

  <section class="space-y-6" id="pipeline-builder-page">
    <section class="dashboard-panel">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="space-y-2">
          <p class="dashboard-card-label">Authoring Contract</p>
          <h2 class="text-xl font-semibold">
            Visual graph editing without losing the canonical DOT loop
          </h2>
        </div>
        <div class="flex flex-wrap gap-2 text-[11px] uppercase tracking-[0.18em] text-base-content/55">
          <span class="rounded-full border border-base-300/80 px-3 py-1">
            visual graph editing
          </span>
          <span class="rounded-full border border-base-300/80 px-3 py-1">dot round-trip</span>
          <span class="rounded-full border border-base-300/80 px-3 py-1">
            runtime-backed types
          </span>
        </div>
      </div>
    </section>

    <div id="builder-shell" class="builder-shell">
      <aside id="builder-left-panel" class="builder-side builder-left">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold tracking-wide">Quick Insert</h2>
          <button id="toggle-left-panel" type="button" class="builder-btn">Hide Left</button>
        </div>

        <div class="builder-command-launcher">
          <button type="button" id="open-command-palette-secondary" class="builder-btn">
            Open Palette <span class="builder-shortcut-pill">Ctrl+K</span>
          </button>
          <button type="button" id="open-builder-shortcuts" class="builder-btn">
            Shortcuts <span class="builder-shortcut-pill">?</span>
          </button>
        </div>

        <div class="builder-left-actions">
          <button type="button" id="add-start" class="builder-btn">Start</button>
          <button type="button" id="add-tool" class="builder-btn">Tool</button>
          <button type="button" id="add-llm" class="builder-btn">LLM</button>
          <button type="button" id="add-wait-human" class="builder-btn">Human</button>
          <button type="button" id="add-conditional" class="builder-btn">Decision</button>
          <button type="button" id="add-parallel" class="builder-btn">Parallel</button>
          <button type="button" id="add-parallel-fan-in" class="builder-btn">Fan-In</button>
          <button type="button" id="add-stack-manager-loop" class="builder-btn">Manager</button>
          <button type="button" id="add-end" class="builder-btn">End</button>
        </div>

        <div class="builder-command-bar">
          <button type="button" id="connect-toggle" class="builder-btn">Add Edges</button>
          <button type="button" id="clear-edges" class="builder-btn">Clear</button>
          <button type="button" id="apply-dot" class="builder-btn">Apply DOT</button>
        </div>

        <div class="space-y-3 rounded-[1.1rem] border border-base-300/80 bg-base-100/90 p-4 shadow-[0_14px_45px_rgba(15,23,42,0.05)]">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h3 class="text-sm font-semibold">Authoring Actions</h3>
              <p class="text-[11px] uppercase tracking-[0.18em] text-base-content/50">
                Canonical parser-backed
              </p>
            </div>
            <div
              id="builder-authoring-status"
              class="rounded-full border border-base-300 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-base-content/60"
            >
              Syncing
            </div>
          </div>

          <label class="space-y-1">
            <span class="text-xs font-semibold">Template</span>
            <select
              id="builder-template-select"
              class="w-full rounded-lg border border-base-300 bg-base-100 px-3 py-2 text-sm"
            >
              <option value="">Loading templates...</option>
            </select>
          </label>

          <div class="flex flex-wrap gap-2">
            <button type="button" id="builder-load-template" class="builder-btn">
              Load Template
            </button>
            <button type="button" id="builder-format-dot" class="builder-btn">
              Format DOT
            </button>
          </div>
        </div>

        <section class="builder-shortcuts-card" id="builder-shortcut-cheatsheet">
          <div class="space-y-1">
            <p class="builder-kicker">Keyboard</p>
            <h3 class="text-sm font-semibold">Stay on the canvas</h3>
          </div>
          <div class="builder-shortcut-grid">
            <div class="builder-shortcut-row">
              <span>Command palette</span>
              <span class="builder-shortcut-pill">Ctrl+K</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Quick add</span>
              <span class="builder-shortcut-pill">Shift+A</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Connect mode</span>
              <span class="builder-shortcut-pill">C</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Fit view</span>
              <span class="builder-shortcut-pill">F</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Inspector</span>
              <span class="builder-shortcut-pill">I</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Delete selected</span>
              <span class="builder-shortcut-pill">Backspace</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Format DOT</span>
              <span class="builder-shortcut-pill">Shift+F</span>
            </div>
            <div class="builder-shortcut-row">
              <span>Run</span>
              <span class="builder-shortcut-pill">Shift+R</span>
            </div>
          </div>
        </section>

        <div
          id="workflow-summary"
          class="builder-summary-host min-h-[220px] rounded-[1.1rem] border border-base-300/80 bg-base-100/90 p-4 text-sm leading-6 shadow-[0_14px_45px_rgba(15,23,42,0.05)]"
        >
        </div>
        <p class="text-xs leading-5 text-base-content/62">
          Drag to reposition nodes. In edge mode, pull from one node to another to create a connection.
        </p>
      </aside>

      <main class="builder-center">
        <div class="flex flex-wrap items-center justify-between gap-3 pb-3">
          <div>
            <p class="builder-kicker">Canvas</p>
            <p class="text-sm text-base-content/65">Direct manipulation with DOT kept in sync.</p>
          </div>
          <button id="toggle-left-panel-center" type="button" class="builder-btn">
            Toggle Left
          </button>
          <button id="toggle-right-panel-center" type="button" class="builder-btn">
            Toggle Right
          </button>
        </div>
        <div
          id="pipeline-builder"
          phx-hook="PipelineBuilder"
          phx-update="ignore"
          class="relative h-[74vh] min-h-[460px] overflow-hidden rounded-xl border border-base-300 bg-base-200/40"
        >
          <div id="builder-canvas-grid" class="builder-canvas-grid"></div>
          <div id="builder-world" class="builder-world">
            <svg id="builder-edges" class="builder-edges-layer">
              <defs>
                <marker
                  id="builder-arrow"
                  viewBox="0 0 10 10"
                  refX="9"
                  refY="5"
                  markerWidth="6"
                  markerHeight="6"
                  orient="auto-start-reverse"
                >
                  <path d="M 0 0 L 10 5 L 0 10 z" class="fill-base-content/70" />
                </marker>
              </defs>
            </svg>
            <div id="builder-canvas" class="builder-canvas-layer"></div>
          </div>
          <div id="builder-marquee" class="builder-marquee hidden"></div>

          <div id="builder-canvas-controls" class="builder-canvas-controls">
            <div class="builder-canvas-controls-group">
              <button id="builder-zoom-in" type="button" class="builder-btn">Zoom In</button>
              <button id="builder-zoom-out" type="button" class="builder-btn">Zoom Out</button>
              <button id="builder-fit-view" type="button" class="builder-btn">Fit</button>
              <button id="builder-reset-view" type="button" class="builder-btn">Reset</button>
            </div>

            <div class="builder-canvas-controls-group">
              <button
                id="builder-interaction-select"
                type="button"
                class="builder-btn"
                data-interaction-mode="select"
              >
                Select
              </button>
              <button
                id="builder-interaction-pan"
                type="button"
                class="builder-btn"
                data-interaction-mode="pan"
              >
                Pan
              </button>
              <button id="builder-canvas-connect" type="button" class="builder-btn">
                Connect
              </button>
            </div>

            <div id="builder-viewport-badge" class="builder-viewport-badge">
              100% · Select
            </div>
          </div>

          <div id="builder-selection-toolbar" class="builder-selection-toolbar hidden">
            <div class="builder-selection-toolbar-copy">
              <p class="builder-kicker">Selection</p>
              <p id="builder-selection-count" class="text-sm font-semibold">0 nodes selected</p>
            </div>
            <div class="builder-selection-toolbar-actions">
              <button id="builder-align-horizontal" type="button" class="builder-btn">
                Align Row
              </button>
              <button id="builder-align-vertical" type="button" class="builder-btn">
                Align Column
              </button>
              <button id="builder-distribute-horizontal" type="button" class="builder-btn">
                Distribute
              </button>
              <button id="builder-duplicate-selection" type="button" class="builder-btn">
                Duplicate
              </button>
              <button id="builder-delete-selection" type="button" class="builder-btn">
                Delete
              </button>
            </div>
          </div>

          <aside id="builder-minimap" class="builder-minimap">
            <div class="builder-minimap-header">
              <div>
                <p class="builder-kicker">Navigator</p>
                <p class="text-xs font-semibold text-base-content/70">Graph overview</p>
              </div>
              <button id="builder-minimap-fit" type="button" class="builder-btn">Fit</button>
            </div>
            <div id="builder-minimap-surface" class="builder-minimap-surface">
              <div id="builder-minimap-nodes" class="builder-minimap-nodes"></div>
              <div id="builder-minimap-viewport" class="builder-minimap-viewport"></div>
            </div>
          </aside>
        </div>

        <dialog
          id="builder-command-palette"
          class="builder-command-palette-dialog rounded-[1.5rem] border border-base-300 p-0 backdrop:bg-slate-950/50"
        >
          <div class="builder-command-palette-shell">
            <div class="builder-command-palette-header">
              <div>
                <p class="builder-kicker">Builder Commands</p>
                <h3 class="text-lg font-semibold">Search actions and node inserts</h3>
              </div>
              <button id="close-command-palette" type="button" class="builder-btn">Close</button>
            </div>

            <label class="builder-command-search-shell" for="builder-command-search">
              <span class="sr-only">Search builder commands</span>
              <input
                id="builder-command-search"
                type="text"
                class="builder-command-search-input"
                placeholder="Search nodes, format DOT, run pipeline, open create..."
                autocomplete="off"
              />
            </label>

            <div class="builder-command-palette-body">
              <div id="builder-command-results" class="builder-command-results" role="listbox">
              </div>
              <div id="builder-command-empty" class="builder-command-empty hidden">
                No matching builder command.
              </div>
            </div>
          </div>
        </dialog>

        <dialog
          id="builder-shortcuts-dialog"
          class="rounded-[1.5rem] border border-base-300 p-0 backdrop:bg-slate-950/50"
        >
          <div class="w-[min(92vw,32rem)] space-y-4 bg-base-100 p-5">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="builder-kicker">Cheat Sheet</p>
                <h3 class="text-lg font-semibold">Builder shortcuts</h3>
              </div>
              <button id="close-builder-shortcuts" type="button" class="builder-btn">
                Close
              </button>
            </div>

            <div class="builder-shortcut-grid">
              <div class="builder-shortcut-row">
                <span>Command palette</span>
                <span class="builder-shortcut-pill">Ctrl+K</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Quick add at cursor</span>
                <span class="builder-shortcut-pill">Shift+A</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Toggle connect mode</span>
                <span class="builder-shortcut-pill">C</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Fit nodes in view</span>
                <span class="builder-shortcut-pill">F</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Open selected inspector</span>
                <span class="builder-shortcut-pill">I</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Delete selected node</span>
                <span class="builder-shortcut-pill">Backspace</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Format DOT</span>
                <span class="builder-shortcut-pill">Shift+F</span>
              </div>
              <div class="builder-shortcut-row">
                <span>Run pipeline</span>
                <span class="builder-shortcut-pill">Shift+R</span>
              </div>
            </div>
          </div>
        </dialog>
      </main>

      <aside id="builder-right-panel" class="builder-side builder-right">
        <div class="flex items-center justify-between">
          <div>
            <p class="builder-kicker">Inspector</p>
            <h2 class="text-sm font-semibold">Graph, diagnostics, source, and runtime</h2>
          </div>
          <button id="toggle-right-panel" type="button" class="builder-btn">Hide Right</button>
        </div>
        <.form
          for={@form}
          id="pipeline-runner-form"
          phx-submit="pipeline_action"
          class="builder-inspector-shell"
        >
          <div id="builder-inspector-tabs" class="builder-inspector-tabs" role="tablist">
            <button
              id="builder-inspector-tab-selection"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="selection"
            >
              Selection
            </button>
            <button
              id="builder-inspector-tab-graph"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="graph"
            >
              Graph
            </button>
            <button
              id="builder-inspector-tab-node"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="node"
            >
              Node
            </button>
            <button
              id="builder-inspector-tab-edge"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="edge"
            >
              Edge
            </button>
            <button
              id="builder-inspector-tab-diagnostics"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="diagnostics"
            >
              Diagnostics
            </button>
            <button
              id="builder-inspector-tab-source"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="source"
            >
              Source
            </button>
            <button
              id="builder-inspector-tab-runtime"
              type="button"
              class="builder-inspector-tab"
              data-inspector-tab="runtime"
            >
              Runtime
            </button>
          </div>

          <section
            id="builder-inspector-panel-selection"
            class="builder-inspector-panel"
            data-inspector-panel="selection"
          >
            <div class="builder-inspector-card">
              <p class="builder-kicker">Selection</p>
              <h3 class="text-base font-semibold">
                Contextual editing stays docked to the canvas
              </h3>
              <p
                id="builder-selection-inspector-copy"
                class="mt-2 text-sm leading-6 text-base-content/68"
              >
                Select a node or edge to edit it here. Multi-select keeps bulk actions on the canvas toolbar.
              </p>
              <div class="builder-selection-summary-grid mt-4">
                <div class="builder-selection-summary-tile">
                  <span class="builder-selection-summary-label">Selected node</span>
                  <strong id="builder-selection-node-name">None</strong>
                </div>
                <div class="builder-selection-summary-tile">
                  <span class="builder-selection-summary-label">Selection count</span>
                  <strong id="builder-selection-inspector-count">0</strong>
                </div>
                <div class="builder-selection-summary-tile">
                  <span class="builder-selection-summary-label">Edge focus</span>
                  <strong id="builder-selection-edge-name">None</strong>
                </div>
              </div>
            </div>
          </section>

          <section
            id="builder-inspector-panel-graph"
            class="builder-inspector-panel hidden"
            data-inspector-panel="graph"
          >
            <div class="builder-inspector-card space-y-4">
              <div>
                <p class="builder-kicker">Graph Inspector</p>
                <h3 class="text-base font-semibold">Graph settings and runtime contract</h3>
              </div>
              <div class="grid gap-3 md:grid-cols-2">
                <label class="space-y-1">
                  <span class="text-xs font-semibold">Goal</span>
                  <input
                    id="graph-goal"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="space-y-1">
                  <span class="text-xs font-semibold">Label</span>
                  <input
                    id="graph-label"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="space-y-1 md:col-span-2">
                  <span class="text-xs font-semibold">Model Stylesheet</span>
                  <textarea
                    id="graph-model-stylesheet"
                    rows="2"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm font-mono"
                  ></textarea>
                </label>
                <label class="space-y-1">
                  <span class="text-xs font-semibold">Default Max Retry</span>
                  <input
                    id="graph-default-max-retry"
                    type="number"
                    min="0"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="space-y-1">
                  <span class="text-xs font-semibold">Default Fidelity</span>
                  <input
                    id="graph-default-fidelity"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="space-y-1">
                  <span class="text-xs font-semibold">Retry Target</span>
                  <input
                    id="graph-retry-target"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="space-y-1">
                  <span class="text-xs font-semibold">Fallback Retry Target</span>
                  <input
                    id="graph-fallback-retry-target"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
              </div>

              <div class="builder-contract-card">
                <h4 class="text-sm font-semibold">Graph Contract</h4>
                <div class="mt-3 space-y-3 text-xs leading-6 text-base-content/75">
                  <div>
                    <p class="font-semibold text-base-content">Node JSON</p>
                    <p class="font-mono">
                      id, type, shape, prompt, goal_gate, retry_target, fallback_retry_target, attrs
                    </p>
                    <p class="mt-1 text-[11px] text-base-content/60">
                      The editor only exposes attrs supported by the runtime for the selected node type.
                    </p>
                  </div>
                  <div>
                    <p class="font-semibold text-base-content">Edge JSON</p>
                    <p class="font-mono">from, to, condition, status, attrs</p>
                    <p class="mt-1 text-[11px] text-base-content/60">
                      Edge rules are limited to default routing, status routing, or condition routing.
                    </p>
                  </div>
                  <p>
                    The builder keeps authoring DOT, but the live contract is the parsed
                    `GET /pipelines/:id/graph?format=json` payload shown in the runtime sidecar.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <section
            id="builder-inspector-panel-node"
            class="builder-inspector-panel hidden"
            data-inspector-panel="node"
          >
            <div class="builder-inspector-card space-y-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="builder-kicker">Node Inspector</p>
                  <h3 class="text-base font-semibold">
                    Edit runtime-backed node fields in place
                  </h3>
                </div>
                <span
                  id="builder-node-inspector-badge"
                  class="rounded-full border border-base-300 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-base-content/60"
                >
                  No node
                </span>
              </div>

              <div class="grid gap-3 md:grid-cols-3">
                <label id="node-prop-wrap-id" class="block space-y-1">
                  <span class="text-xs font-semibold">ID</span>
                  <input
                    id="node-prop-id"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-label" class="block space-y-1">
                  <span class="text-xs font-semibold">Label</span>
                  <input
                    id="node-prop-label"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-type" class="block space-y-1">
                  <span class="text-xs font-semibold">Type</span>
                  <select
                    id="node-prop-type"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="start">start</option>
                    <option value="tool">tool</option>
                    <option value="wait.human">wait.human</option>
                    <option value="wait_for_human">wait_for_human</option>
                    <option value="conditional">conditional</option>
                    <option value="parallel">parallel</option>
                    <option value="parallel.fan_in">parallel.fan_in</option>
                    <option value="stack.manager_loop">stack.manager_loop</option>
                    <option value="codergen">codergen</option>
                    <option value="exit">exit</option>
                  </select>
                </label>
              </div>

              <div class="grid gap-3 md:grid-cols-2">
                <label id="node-prop-wrap-prompt" class="block space-y-1 md:col-span-2">
                  <span class="text-xs font-semibold">Prompt</span>
                  <textarea
                    id="node-prop-prompt"
                    rows="3"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  ></textarea>
                </label>
                <label id="node-prop-wrap-class" class="block space-y-1">
                  <span class="text-xs font-semibold">Class</span>
                  <input
                    id="node-prop-class"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-timeout" class="block space-y-1">
                  <span class="text-xs font-semibold">Timeout</span>
                  <input
                    id="node-prop-timeout"
                    placeholder="900s"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-max-retries" class="block space-y-1">
                  <span class="text-xs font-semibold">Max Retries</span>
                  <input
                    id="node-prop-max-retries"
                    type="number"
                    min="0"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-fidelity" class="block space-y-1">
                  <span class="text-xs font-semibold">Fidelity</span>
                  <select
                    id="node-prop-fidelity"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(default)</option>
                    <option value="full">full</option>
                    <option value="truncate">truncate</option>
                    <option value="compact">compact</option>
                    <option value="summary:low">summary:low</option>
                    <option value="summary:medium">summary:medium</option>
                    <option value="summary:high">summary:high</option>
                  </select>
                </label>
                <label id="node-prop-wrap-thread-id" class="block space-y-1">
                  <span class="text-xs font-semibold">Thread ID</span>
                  <input
                    id="node-prop-thread-id"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-retry-target" class="block space-y-1">
                  <span class="text-xs font-semibold">Retry Target</span>
                  <select
                    id="node-prop-retry-target"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(none)</option>
                  </select>
                </label>
                <label id="node-prop-wrap-fallback-retry-target" class="block space-y-1">
                  <span class="text-xs font-semibold">Fallback Retry Target</span>
                  <select
                    id="node-prop-fallback-retry-target"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(none)</option>
                  </select>
                </label>
                <label id="node-prop-wrap-llm-model" class="block space-y-1">
                  <span class="text-xs font-semibold">LLM Model</span>
                  <input
                    id="node-prop-llm-model"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-llm-provider" class="block space-y-1">
                  <span class="text-xs font-semibold">LLM Provider</span>
                  <input
                    id="node-prop-llm-provider"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-reasoning-effort" class="block space-y-1">
                  <span class="text-xs font-semibold">Reasoning Effort</span>
                  <select
                    id="node-prop-reasoning-effort"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(default)</option>
                    <option value="low">low</option>
                    <option value="medium">medium</option>
                    <option value="high">high</option>
                  </select>
                </label>
                <label id="node-prop-wrap-max-tokens" class="block space-y-1">
                  <span class="text-xs font-semibold">Max Tokens</span>
                  <input
                    id="node-prop-max-tokens"
                    type="number"
                    min="1"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-temperature" class="block space-y-1">
                  <span class="text-xs font-semibold">Temperature</span>
                  <input
                    id="node-prop-temperature"
                    type="number"
                    min="0"
                    max="2"
                    step="0.1"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <div id="node-prop-wrap-command" class="space-y-1">
                  <span class="text-xs font-semibold">Tool Command</span>
                  <input
                    id="node-prop-command"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm font-mono"
                  />
                </div>
                <label id="node-prop-wrap-human-default-choice" class="block space-y-1">
                  <span class="text-xs font-semibold">Human Default Choice</span>
                  <input
                    id="node-prop-human-default-choice"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-human-timeout" class="block space-y-1">
                  <span class="text-xs font-semibold">Human Timeout</span>
                  <input
                    id="node-prop-human-timeout"
                    placeholder="30s"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-human-input" class="block space-y-1">
                  <span class="text-xs font-semibold">Human Input</span>
                  <select
                    id="node-prop-human-input"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(default)</option>
                    <option value="text">text</option>
                    <option value="textarea">textarea</option>
                    <option value="checkbox">checkbox</option>
                    <option value="boolean">boolean</option>
                    <option value="confirmation">confirmation</option>
                    <option value="single_select">single_select</option>
                    <option value="multi_select">multi_select</option>
                    <option value="radio">radio</option>
                    <option value="select">select</option>
                  </select>
                </label>
                <label
                  id="node-prop-wrap-human-multiple"
                  class="flex items-center gap-2 text-xs font-semibold"
                >
                  <input id="node-prop-human-multiple" type="checkbox" /> human.multiple
                </label>
                <label
                  id="node-prop-wrap-human-required"
                  class="flex items-center gap-2 text-xs font-semibold"
                >
                  <input id="node-prop-human-required" type="checkbox" /> human.required
                </label>
                <label id="node-prop-wrap-join-policy" class="block space-y-1">
                  <span class="text-xs font-semibold">Join Policy</span>
                  <select
                    id="node-prop-join-policy"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(default)</option>
                    <option value="wait_all">wait_all</option>
                    <option value="first_success">first_success</option>
                    <option value="k_of_n">k_of_n</option>
                    <option value="quorum">quorum</option>
                  </select>
                </label>
                <label id="node-prop-wrap-max-parallel" class="block space-y-1">
                  <span class="text-xs font-semibold">Max Parallel</span>
                  <input
                    id="node-prop-max-parallel"
                    type="number"
                    min="1"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-k" class="block space-y-1">
                  <span class="text-xs font-semibold">K</span>
                  <input
                    id="node-prop-k"
                    type="number"
                    min="1"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-quorum-ratio" class="block space-y-1">
                  <span class="text-xs font-semibold">Quorum Ratio</span>
                  <input
                    id="node-prop-quorum-ratio"
                    type="number"
                    min="0"
                    max="1"
                    step="0.01"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-manager-actions" class="block space-y-1">
                  <span class="text-xs font-semibold">Manager Actions</span>
                  <input
                    id="node-prop-manager-actions"
                    placeholder="observe,wait,steer"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-manager-max-cycles" class="block space-y-1">
                  <span class="text-xs font-semibold">Manager Max Cycles</span>
                  <input
                    id="node-prop-manager-max-cycles"
                    type="number"
                    min="1"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-manager-poll-interval" class="block space-y-1">
                  <span class="text-xs font-semibold">Manager Poll Interval</span>
                  <input
                    id="node-prop-manager-poll-interval"
                    placeholder="500ms"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label id="node-prop-wrap-manager-stop-condition" class="block space-y-1">
                  <span class="text-xs font-semibold">Manager Stop Condition</span>
                  <input
                    id="node-prop-manager-stop-condition"
                    placeholder={"context.stack.child.status == \"completed\""}
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label
                  id="node-prop-wrap-stack-child-autostart"
                  class="flex items-center gap-2 text-xs font-semibold"
                >
                  <input id="node-prop-stack-child-autostart" type="checkbox" />
                  stack.child_autostart
                </label>
                <label
                  id="node-prop-wrap-goal-gate"
                  class="flex items-center gap-2 text-xs font-semibold"
                >
                  <input id="node-prop-goal-gate" type="checkbox" /> goal_gate
                </label>
                <label
                  id="node-prop-wrap-auto-status"
                  class="flex items-center gap-2 text-xs font-semibold"
                >
                  <input id="node-prop-auto-status" type="checkbox" /> auto_status
                </label>
                <label
                  id="node-prop-wrap-allow-partial"
                  class="flex items-center gap-2 text-xs font-semibold"
                >
                  <input id="node-prop-allow-partial" type="checkbox" /> allow_partial
                </label>
              </div>

              <div
                id="node-prop-wrap-edges"
                class="space-y-2 rounded-lg border border-base-300 p-3"
              >
                <div class="flex items-center justify-between">
                  <div class="space-y-1">
                    <span class="block text-xs font-semibold uppercase tracking-wide text-base-content/70">
                      Edges
                    </span>
                    <span class="block text-[10px] uppercase tracking-wide text-base-content/50">
                      source -&gt; target
                    </span>
                  </div>
                  <button id="node-prop-add-edge" class="builder-btn" type="button">
                    + Add Edge
                  </button>
                </div>
                <div id="node-edges-list" class="space-y-2"></div>
              </div>

              <div class="flex items-center justify-end gap-2 pt-2">
                <button id="node-prop-delete" class="builder-btn" type="button">
                  Delete Node
                </button>
                <button id="node-prop-cancel" class="builder-btn" type="button">
                  Close
                </button>
                <button id="node-prop-save" class="builder-btn" type="button">
                  Save
                </button>
              </div>
            </div>
          </section>

          <section
            id="builder-inspector-panel-edge"
            class="builder-inspector-panel hidden"
            data-inspector-panel="edge"
          >
            <div class="builder-inspector-card space-y-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="builder-kicker">Edge Inspector</p>
                  <h3 class="text-base font-semibold">Tune routing without leaving the canvas</h3>
                </div>
                <span
                  id="builder-edge-inspector-badge"
                  class="rounded-full border border-base-300 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-base-content/60"
                >
                  No edge
                </span>
              </div>

              <div class="grid gap-3 md:grid-cols-2">
                <label class="block space-y-1">
                  <span class="text-xs font-semibold">Source</span>
                  <select
                    id="edge-prop-source"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                  </select>
                </label>
                <label class="block space-y-1">
                  <span class="text-xs font-semibold">Target</span>
                  <select
                    id="edge-prop-target"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                  </select>
                </label>
                <label class="block space-y-1">
                  <span class="text-xs font-semibold">Rule</span>
                  <select
                    id="edge-prop-mode"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="default">default</option>
                    <option value="status">status</option>
                    <option value="condition">condition</option>
                  </select>
                </label>
                <div class="space-y-1">
                  <label id="edge-prop-value-wrap" class="block space-y-1">
                    <span class="text-xs font-semibold">Value</span>
                    <input
                      id="edge-prop-value"
                      class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm font-mono"
                    />
                  </label>
                  <label id="edge-prop-status-wrap" class="block space-y-1">
                    <span class="text-xs font-semibold">Status</span>
                    <select
                      id="edge-prop-status"
                      class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                    >
                      <option value="success">success</option>
                      <option value="fail">fail</option>
                      <option value="retry">retry</option>
                      <option value="partial_success">partial_success</option>
                    </select>
                  </label>
                </div>
                <label class="block space-y-1 md:col-span-2">
                  <span class="text-xs font-semibold">Label</span>
                  <input
                    id="edge-prop-label"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="block space-y-1">
                  <span class="text-xs font-semibold">Weight</span>
                  <input
                    id="edge-prop-weight"
                    type="number"
                    step="1"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="block space-y-1">
                  <span class="text-xs font-semibold">Fidelity</span>
                  <select
                    id="edge-prop-fidelity"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  >
                    <option value="">(default)</option>
                    <option value="full">full</option>
                    <option value="truncate">truncate</option>
                    <option value="compact">compact</option>
                    <option value="summary:low">summary:low</option>
                    <option value="summary:medium">summary:medium</option>
                    <option value="summary:high">summary:high</option>
                  </select>
                </label>
                <label class="block space-y-1">
                  <span class="text-xs font-semibold">Thread ID</span>
                  <input
                    id="edge-prop-thread-id"
                    class="w-full rounded border border-base-300 bg-base-100 px-2 py-1 text-sm"
                  />
                </label>
                <label class="flex items-center gap-2 text-xs font-semibold">
                  <input id="edge-prop-loop-restart" type="checkbox" /> loop_restart
                </label>
              </div>

              <div class="flex items-center justify-between gap-2 pt-2">
                <button id="edge-prop-delete" class="builder-btn" type="button">
                  Delete Edge
                </button>
                <div class="flex items-center gap-2">
                  <button id="edge-prop-cancel" class="builder-btn" type="button">
                    Close
                  </button>
                  <button id="edge-prop-save" class="builder-btn" type="button">
                    Save Edge
                  </button>
                </div>
              </div>
            </div>
          </section>

          <section
            id="builder-inspector-panel-diagnostics"
            class="builder-inspector-panel hidden"
            data-inspector-panel="diagnostics"
          >
            <div id="builder-diagnostics-panel" class="builder-inspector-card space-y-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="builder-kicker">Diagnostics</p>
                  <h3 class="text-base font-semibold">Parser and validator feedback</h3>
                  <p id="builder-diagnostics-summary" class="mt-2 text-xs text-base-content/65">
                    Canonical parser and validator diagnostics appear here.
                  </p>
                </div>
              </div>

              <div id="builder-autofix-actions" class="flex flex-wrap gap-2"></div>
              <div
                id="builder-diagnostics-list"
                class="space-y-2 text-xs text-base-content/75"
              >
              </div>
            </div>
          </section>

          <section
            id="builder-inspector-panel-source"
            class="builder-inspector-panel hidden"
            data-inspector-panel="source"
          >
            <div class="builder-inspector-card space-y-4">
              <div>
                <p class="builder-kicker">Source</p>
                <h3 class="text-base font-semibold">
                  DOT, context, and library save live together
                </h3>
              </div>

              <%= if @loaded_library_entry do %>
                <div
                  id="builder-library-banner"
                  class="rounded-2xl border border-base-300 bg-base-200/60 px-4 py-3"
                >
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-base-content/55">
                        Loaded from library
                      </p>
                      <p class="text-sm font-semibold">
                        {@loaded_library_entry.name}
                        <span class="font-mono text-xs text-base-content/60">
                          ({@loaded_library_entry.id})
                        </span>
                      </p>
                    </div>
                    <.link
                      navigate={~p"/library/#{@loaded_library_entry.id}/edit"}
                      class="builder-btn"
                    >
                      Manage Entry
                    </.link>
                  </div>
                </div>
              <% end %>

              <div class="space-y-2">
                <label class="text-sm font-semibold" for="pipeline-dot">Pipeline DOT</label>
                <.input
                  field={@form[:dot]}
                  id="pipeline-dot"
                  type="textarea"
                  rows="16"
                  class="w-full rounded-xl border border-base-300 bg-base-100 p-3 font-mono text-xs"
                />
              </div>

              <div class="space-y-2">
                <label class="text-sm font-semibold" for="pipeline-context-json">
                  Context JSON
                </label>
                <.input
                  field={@form[:context_json]}
                  id="pipeline-context-json"
                  type="textarea"
                  rows="6"
                  class="w-full rounded-xl border border-base-300 bg-base-100 p-3 font-mono text-xs"
                />
              </div>

              <div class="space-y-3 rounded-2xl border border-base-300 bg-base-100 p-4">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <h3 class="text-sm font-semibold">Library Save</h3>
                    <p class="text-xs text-base-content/65">
                      Store this builder state for future loading.
                    </p>
                  </div>
                  <.link navigate={~p"/library"} class="builder-btn">
                    Open Library
                  </.link>
                </div>

                <.input
                  field={@form[:library_name]}
                  id="pipeline-library-name"
                  type="text"
                  label="Library Name"
                />

                <.input
                  field={@form[:library_description]}
                  id="pipeline-library-description"
                  type="textarea"
                  rows="3"
                  label="Library Description"
                />

                <div class="flex flex-wrap gap-2">
                  <button
                    id="save-pipeline-library"
                    name="pipeline[action]"
                    value="save_library"
                    type="submit"
                    class="rounded-lg border border-base-300 bg-base-100 px-4 py-2 text-sm font-semibold transition hover:bg-base-200"
                  >
                    Save to Library
                  </button>
                </div>
              </div>
            </div>
          </section>

          <section
            id="builder-inspector-panel-runtime"
            class="builder-inspector-panel hidden"
            data-inspector-panel="runtime"
          >
            <div class="builder-inspector-card space-y-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="builder-kicker">Runtime</p>
                  <h3 class="text-base font-semibold">Run controls and recent feedback</h3>
                  <p class="mt-2 text-sm leading-6 text-base-content/68">
                    Submit the current DOT and context without leaving the builder.
                  </p>
                </div>
                <span
                  id="builder-runtime-status-badge"
                  class={[
                    "run-status-pill",
                    cond do
                      @status in [nil, "", :running, "running"] -> "run-status-running"
                      @status in [:success, "success"] -> "run-status-success"
                      @status in [:fail, "fail"] -> "run-status-fail"
                      @status in [:cancelled, "cancelled"] -> "run-status-cancelled"
                      true -> "run-status-question"
                    end
                  ]}
                >
                  {if @status in [nil, ""], do: "idle", else: @status}
                </span>
              </div>

              <.inline_error
                :if={@error}
                id="run-error"
                title="Pipeline action failed"
                message={@error}
              />

              <div class="flex flex-wrap gap-2">
                <button
                  id="run-pipeline"
                  name="pipeline[action]"
                  value="run"
                  type="submit"
                  class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-500"
                >
                  Run via /run
                </button>
                <button
                  id="submit-pipeline"
                  name="pipeline[action]"
                  value="pipelines"
                  type="submit"
                  class="rounded-lg border border-base-300 bg-base-100 px-4 py-2 text-sm font-semibold transition hover:bg-base-200"
                >
                  Submit via /pipelines
                </button>
              </div>

              <div class="builder-runtime-summary-grid">
                <div class="builder-runtime-summary-card">
                  <span class="builder-runtime-summary-label">Endpoint</span>
                  <strong>
                    {if @result && @result.submit_endpoint == "pipelines",
                      do: "POST /pipelines",
                      else: "POST /run"}
                  </strong>
                </div>
                <div class="builder-runtime-summary-card">
                  <span class="builder-runtime-summary-label">Pending Questions</span>
                  <strong>{length(@questions)}</strong>
                </div>
                <div class="builder-runtime-summary-card">
                  <span class="builder-runtime-summary-label">Recent Events</span>
                  <strong>{length(@events)}</strong>
                </div>
              </div>

              <%= if @result do %>
                <div id="run-result" class="builder-runtime-result space-y-4">
                  <div class="builder-runtime-result-header">
                    <div>
                      <h4 class="text-sm font-semibold">Latest Run</h4>
                      <p class="text-xs text-base-content/65">
                        Authoring and execution stay in one sidecar.
                      </p>
                    </div>
                    <.link
                      navigate={~p"/runs/#{@result.run_id}"}
                      id="open-run-detail"
                      class="builder-btn"
                    >
                      Open Run Detail
                    </.link>
                  </div>

                  <div class="builder-runtime-summary-grid">
                    <div class="builder-runtime-summary-card">
                      <span class="builder-runtime-summary-label">Status</span>
                      <strong>{@result.status}</strong>
                    </div>
                    <div class="builder-runtime-summary-card">
                      <span class="builder-runtime-summary-label">Run ID</span>
                      <strong class="font-mono text-xs">{@result.run_id}</strong>
                    </div>
                    <div class="builder-runtime-summary-card">
                      <span class="builder-runtime-summary-label">Logs Root</span>
                      <strong class="font-mono text-xs">{@result.logs_root}</strong>
                    </div>
                  </div>

                  <%= if @events != [] do %>
                    <div class="space-y-2 rounded-lg border border-base-300 bg-base-100 p-3">
                      <div class="flex items-center justify-between gap-3">
                        <h5 class="text-sm font-semibold">Recent Events</h5>
                        <span class="text-xs text-base-content/60">{length(@events)} total</span>
                      </div>
                      <div class="space-y-2">
                        <%= for event <- Enum.take(Enum.reverse(@events), 5) do %>
                          <div class="rounded-lg border border-base-300/70 px-3 py-2 text-xs">
                            <div class="flex items-center justify-between gap-3">
                              <span class="font-semibold">{event["type"] || "event"}</span>
                              <span class="text-base-content/60">{event["timestamp"]}</span>
                            </div>
                            <%= if event["status"] do %>
                              <p class="mt-1 text-base-content/70">status: {event["status"]}</p>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>

                  <%= if @checkpoint do %>
                    <details class="builder-runtime-details" open>
                      <summary>Checkpoint</summary>
                      <pre class="mt-3 overflow-x-auto text-xs"><%= Jason.encode_to_iodata!(@checkpoint, pretty: true) %></pre>
                    </details>
                  <% end %>

                  <%= if is_map(get_in(@result, [:context, "tools"])) and map_size(get_in(@result, [:context, "tools"])) > 0 do %>
                    <details id="command-output" class="builder-runtime-details">
                      <summary>Command Output</summary>
                      <div class="mt-3 space-y-3">
                        <%= for {node_id, output} <- get_in(@result, [:context, "tools"]) do %>
                          <div class="space-y-1">
                            <p class="text-xs font-semibold text-base-content/70">{node_id}</p>
                            <pre class="overflow-x-auto rounded border border-base-300 bg-base-100 p-2 text-xs">{output}</pre>
                          </div>
                        <% end %>
                      </div>
                    </details>
                  <% end %>

                  <%= if is_map(@graph_json) and map_size(@graph_json) > 0 do %>
                    <details class="builder-runtime-details">
                      <summary>Graph JSON</summary>
                      <p class="mt-3 text-xs text-base-content/65">
                        Canonical node contract:
                        <code>
                          id, type, shape, prompt, goal_gate, retry_target, fallback_retry_target, attrs
                        </code>
                      </p>
                      <p class="text-xs text-base-content/65">
                        Canonical edge contract: <code>from, to, condition, status, attrs</code>
                      </p>
                      <pre class="mt-3 overflow-x-auto rounded border border-base-300 bg-base-100 p-2 text-xs"><%= Jason.encode_to_iodata!(@graph_json, pretty: true) %></pre>
                    </details>
                  <% end %>

                  <details class="builder-runtime-details">
                    <summary>Full Run Payload</summary>
                    <pre class="mt-3 overflow-x-auto rounded-lg bg-base-100 p-3 text-xs"><%= Jason.encode_to_iodata!(@result, pretty: true) %></pre>
                  </details>
                </div>
              <% else %>
                <div class="builder-runtime-empty">
                  <p class="text-sm font-semibold">No run yet</p>
                  <p class="text-xs leading-5 text-base-content/65">
                    The builder will keep recent status, questions, and events here after you run or submit the current graph.
                  </p>
                </div>
              <% end %>

              <div class="rounded-2xl border border-base-300 bg-base-100 p-4">
                <h4 class="text-sm font-semibold">Operator Handoff</h4>
                <p class="mt-2 text-xs leading-5 text-base-content/65">
                  Continue into the richer operator and debugger surfaces when you need full topology or timeline detail.
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <.link navigate={~p"/"} class="builder-btn">Open Dashboard</.link>
                  <%= if @result do %>
                    <.link navigate={~p"/runs/#{@result.run_id}/debugger"} class="builder-btn">
                      Open Debugger Context
                    </.link>
                  <% else %>
                    <.link navigate={~p"/"} class="builder-btn">
                      Open Operator Views
                    </.link>
                  <% end %>
                </div>
              </div>
            </div>
          </section>
        </.form>
      </aside>
    </div>
  </section>
</Layouts.app>
